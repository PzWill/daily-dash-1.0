<Window x:Class="DailyDash.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DailyDash.Views"
        xmlns:helpers="clr-namespace:DailyDash.Helpers"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:localControls="clr-namespace:DailyDash.Controls"
        xmlns:models="clr-namespace:DailyDash.Models"
        xmlns:dd="urn:gong-wpf-dragdrop"
        Title="Daily Dash" Height="1000" Width="1600"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        WindowStartupLocation="CenterScreen"
        TextElement.FontSize="{DynamicResource AppFontSize}">
    
    <Window.Resources>
        <!-- Animations -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.3"/>
        </Storyboard>

        <Style x:Key="FadeInGridStyle" TargetType="FrameworkElement">
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource FadeInStoryboard}"/>
                </EventTrigger>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource FadeInStoryboard}"/>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- No calendar styles needed - using custom calendar control -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <helpers:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <helpers:InverseBooleanConverter x:Key="InverseBool" />
        <helpers:BooleanToDoubleConverter x:Key="BoolToDouble" />
        
        <DataTemplate x:Key="KanbanCardTemplate">
            <Border Background="#1AFFFFFF" CornerRadius="8" Padding="12" Margin="0,0,0,12" MaxWidth="300" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding DataContext.NavigateToProjectIdeaDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                  CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <!-- Drop Shadow for elevation -->
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="5" Opacity="0.3" Direction="270" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" BorderThickness="0" Foreground="White" FontSize="{DynamicResource FontSize_14}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,8,4"/>
                        
                        <Button Grid.Column="1" Content="✖" FontSize="{DynamicResource FontSize_9}" Padding="2" MinWidth="16" MinHeight="16"
                                Command="{Binding DataContext.RemoveProjectIdeaCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                CommandParameter="{Binding}" Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
                    </Grid>
                    
                    <TextBox Grid.Row="1" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0" Foreground="#AAA" FontSize="{DynamicResource FontSize_12}" TextWrapping="Wrap" Margin="0,4,0,8"
                             local:PlaceholderHelper.Placeholder="Adicionar detalhes..."/>
                    
                    <Border Grid.Row="2" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Background="#20FFFFFF">
                        <TextBlock Text="Projetos" FontSize="{DynamicResource FontSize_10}" Foreground="{DynamicResource PrimaryAccentBrush}" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <!-- GlassFrameThickness=-1 enables the DWM glass effect to cover the entire window -->
        <WindowChrome GlassFrameThickness="-1" CaptionHeight="0" ResizeBorderThickness="8" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <!-- Global Grid Overlay to give a bit of tint over the acrylic blur -->
    <Grid Background="#401A1A1A" x:Name="RootLayout">
        
        <!-- Main Layout with Columns -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="Auto" MinWidth="0" MaxWidth="{Binding IsLeftSidebarOpen, Converter={StaticResource BoolToDouble}, ConverterParameter=500}" />
                <ColumnDefinition Width="Auto" />
                <!-- Main Content -->
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
                <!-- Right Panel (Goals/Heatmap) -->
                <ColumnDefinition Width="Auto" MinWidth="0" MaxWidth="{Binding IsRightSidebarOpen, Converter={StaticResource BoolToDouble}, ConverterParameter=600}" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar (Left) -->
            <Border Grid.Column="0" MinWidth="250" Style="{StaticResource FadeInGridStyle}" Visibility="{Binding IsLeftSidebarOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="#20FFFFFF" BorderThickness="0,0,1,0" Padding="20">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Daily Dash" FontSize="{DynamicResource FontSize_28}" FontWeight="Bold" Foreground="White" Margin="0,10,0,30" />
                
                <local:CustomCalendar Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,0,0,20"
                                      SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Deadlines="{Binding AllGoalsWithDeadlines}"/>
                
                <!-- Monthly Goals Section in Sidebar -->
                <Border Grid.Row="2" Background="#10FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <ToggleButton IsChecked="{Binding IsMonthlyGoalsExpanded, FallbackValue=True}" Command="{Binding ToggleMonthlyGoalsCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Grid Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Metas Mensais" FontSize="{DynamicResource FontSize_16}" FontWeight="SemiBold" Foreground="#FFD700"/>
                                        <TextBlock Grid.Column="1" Text="▼" Foreground="#AAA" VerticalAlignment="Center" x:Name="chevron" FontSize="10"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter TargetName="chevron" Property="Text" Value="▶"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="chevron" Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Visibility="{Binding IsMonthlyGoalsExpanded, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding MonthlyGoals}" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MonthlyGoals.Count}" Value="0">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate>
                                                                <TextBlock Text="Nenhuma meta mensal. Adicione uma abaixo! 🌟" 
                                                                           Foreground="#60FFFFFF" FontSize="{DynamicResource FontSize_11}" FontStyle="Italic" 
                                                                           HorizontalAlignment="Center" Margin="0,10,0,15"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#10FFFFFF" CornerRadius="6" Margin="0,0,0,8" Padding="8">
                                                <StackPanel>
                                                    <!-- Goal header: checkbox + title + remove -->
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <CheckBox IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Margin="0,4,8,0"/>
                                                        
                                                        <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                                 Background="Transparent" BorderThickness="0" Foreground="White" FontSize="{DynamicResource FontSize_12}" FontWeight="SemiBold" VerticalAlignment="Top"
                                                                 TextWrapping="Wrap" Style="{DynamicResource StrikethroughStyle}" Margin="0,2,8,2"/>
                                                        
                                                        <Button Grid.Column="2" Content="✖" FontSize="{DynamicResource FontSize_9}" Padding="2" MinWidth="16" MinHeight="16"
                                                                Command="{Binding DataContext.RemoveMonthlyGoalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                                CommandParameter="{Binding}" Foreground="#666" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>

                                                        <!-- Action buttons row -->
                                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,4">
                                                            <Border CornerRadius="4" Padding="4,1" Margin="0,0,8,0" VerticalAlignment="Center" Cursor="Hand" Background="{Binding TagColor}">
                                                                <Border.InputBindings>
                                                                    <MouseBinding MouseAction="LeftDoubleClick" 
                                                                                  Command="{Binding DataContext.EditSpecificTagCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                                                  CommandParameter="{Binding}"/>
                                                                </Border.InputBindings>
                                                                <TextBlock Text="{Binding Tag}" FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Tag}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                            </Border>

                                                            <ToggleButton x:Name="LinkMenuBtnM" Content="? Hoje" FontSize="{DynamicResource FontSize_9}" Padding="4,2" Margin="0,0,6,0"
                                                                          Foreground="#888" Background="#15FFFFFF" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                                                <ToggleButton.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="4"/>
                                                                    </Style>
                                                                </ToggleButton.Resources>
                                                            </ToggleButton>
                                                            <Popup IsOpen="{Binding IsChecked, ElementName=LinkMenuBtnM}" PlacementTarget="{Binding ElementName=LinkMenuBtnM}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" VerticalOffset="2">
                                                                <Border Background="#2B2B2B" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="4" Padding="2">
                                                                    <StackPanel>
                                                                        <Button Content="Enviar para Hoje (Manter Vínculo)" Command="{Binding DataContext.LinkGoalToTodayCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                        <Button Content="Enviar para Hoje (Apenas Cópia)" Command="{Binding DataContext.CopyGoalToTodayCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                        <Button Content="Enviar para Semana (Manter Vínculo)" Command="{Binding DataContext.LinkGoalToWeeklyCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                        <Button Content="Enviar para Semana (Apenas Cópia)" Command="{Binding DataContext.CopyGoalToWeeklyCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Popup>
                                                        </StackPanel>
                                                    </Grid>

                                                        <!-- Description -->
                                                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                                 Background="Transparent" BorderThickness="0" Foreground="#AAA" FontSize="{DynamicResource FontSize_10}" FontStyle="Italic"
                                                                 Margin="22,2,0,0" TextWrapping="Wrap"
                                                                 local:PlaceholderHelper.Placeholder="Adicionar descrição..."/>

                                                        <!-- Deadline -->
                                                        <StackPanel Orientation="Horizontal" Margin="22,4,0,0">
                                                            <TextBlock Text="Prazo:" Foreground="#888" FontSize="{DynamicResource FontSize_10}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <ToggleButton x:Name="DeadlineBtnM" Foreground="#FFF" Background="#20FFFFFF" BorderThickness="0" Cursor="Hand" Padding="6,2" VerticalAlignment="Center">
                                                                <ToggleButton.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="4"/>
                                                                    </Style>
                                                                </ToggleButton.Resources>
                                                                <TextBlock Text="{Binding Deadline, StringFormat='{}{0:dd/MM/yyyy}', TargetNullValue='Selecionar data'}" FontSize="{DynamicResource FontSize_10}"/>
                                                            </ToggleButton>
                                                            <Popup IsOpen="{Binding IsChecked, ElementName=DeadlineBtnM}" StaysOpen="False" PlacementTarget="{Binding ElementName=DeadlineBtnM}" Placement="Bottom" AllowsTransparency="True" VerticalOffset="2">
                                                                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="8" Padding="10">
                                                                    <local:CustomCalendar SelectedDate="{Binding Deadline, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                </Border>
                                                            </Popup>
                                                            <Button Content="✖" Foreground="#A44" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" Padding="2" FontSize="{DynamicResource FontSize_8}"
                                                                    Click="ClearDeadline_Click" Tag="{Binding}" VerticalAlignment="Center" ToolTip="Remover Prazo">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Deadline}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </StackPanel>

                                                    <!-- Completion Slider -->
                                                    <Grid Margin="0,4,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Slider Minimum="0" Maximum="100" 
                                                                Value="{Binding CompletionPercent, UpdateSourceTrigger=PropertyChanged}" 
                                                                VerticalAlignment="Center" Margin="0,0,6,0"
                                                                Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                                        <TextBlock Grid.Column="1" Foreground="#AAA" FontSize="{DynamicResource FontSize_10}" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <Binding Path="CompletionPercent" StringFormat="{}{0}%"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </Grid>
                                                    
                                                    <!-- Progress bar visual -->
                                                    <Grid Margin="0,3,0,1" Height="3">
                                                        <Border Background="#20FFFFFF" CornerRadius="2"/>
                                                        <Border Background="#FFD700" CornerRadius="2" HorizontalAlignment="Left">
                                                            <Border.Width>
                                                                <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                                                    <Binding Path="CompletionPercent"/>
                                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Sub-tasks list -->
                                                    <ItemsControl ItemsSource="{Binding NoteBlocks}" Margin="18,4,0,0">
                                                        <ItemsControl.Resources>
                                                            <DataTemplate DataType="{x:Type models:TextBlockItem}">
                                                                <Grid Height="0" Visibility="Collapsed"/>
                                                            </DataTemplate>
                                                            <DataTemplate DataType="{x:Type models:TaskItem}">
                                                                <Grid Margin="0,2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <CheckBox IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Margin="0,2,4,0"/>
                                                                    <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                                             Background="Transparent" BorderThickness="0" Foreground="#CCC" FontSize="{DynamicResource FontSize_11}" VerticalAlignment="Top"
                                                                             TextWrapping="Wrap" Style="{DynamicResource StrikethroughStyle}"/>
                                                                    <ToggleButton x:Name="LinkMenuBtnMSub" Grid.Column="2" Content="➡" FontSize="{DynamicResource FontSize_8}" Padding="3,1" Margin="0,0,6,0"
                                                                                  Foreground="#AAA" Background="#20FFFFFF" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                                                        <ToggleButton.Resources>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="CornerRadius" Value="4"/>
                                                                            </Style>
                                                                        </ToggleButton.Resources>
                                                                    </ToggleButton>
                                                                    <Popup IsOpen="{Binding IsChecked, ElementName=LinkMenuBtnMSub}" PlacementTarget="{Binding ElementName=LinkMenuBtnMSub}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" VerticalOffset="2">
                                                                        <Border Background="#2B2B2B" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="4" Padding="2">
                                                                            <StackPanel>
                                                                                <Button Content="Enviar para Hoje (Manter Vínculo)" Command="{Binding DataContext.LinkGoalToTodayCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                                <Button Content="Enviar para Hoje (Apenas Cópia)" Command="{Binding DataContext.CopyGoalToTodayCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                                <Button Content="Enviar para Semana (Manter Vínculo)" Command="{Binding DataContext.LinkGoalToWeeklyCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                                <Button Content="Enviar para Semana (Apenas Cópia)" Command="{Binding DataContext.CopyGoalToWeeklyCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </Popup>
                                                                    <Button Grid.Column="3" Content="✖" FontSize="{DynamicResource FontSize_7}" Padding="1" MinWidth="12" MinHeight="12"
                                                                            Command="{Binding DataContext.RemoveSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding}" Foreground="#666" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.Resources>
                                                    </ItemsControl>

                                                    <!-- Add sub-task button -->
                                                    <Button Content="+ Sub-tarefa" HorizontalAlignment="Left" Margin="18,2,0,0" Padding="0" FontSize="{DynamicResource FontSize_10}"
                                                            Command="{Binding DataContext.AddMonthlySubTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Add new monthly goal input -->
                                <TextBox Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#40FFFFFF" Foreground="#AAA"
                                         Margin="0,3,0,0" Text="{Binding NewMonthlyGoalTitle, UpdateSourceTrigger=PropertyChanged}" Padding="0,4" FontSize="{DynamicResource FontSize_11}">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding AddMonthlyGoalCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Content="+ Adicionar Meta" Command="{Binding AddMonthlyGoalCommand}" HorizontalAlignment="Left" Background="Transparent" Foreground="#FFD700" BorderThickness="0" Cursor="Hand" Margin="0,3,0,0" FontSize="{DynamicResource FontSize_11}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="0,0,0,20">
                    <Button Content="📁 Projetos &amp; Ideias" Command="{Binding SetProjectsViewActiveCommand}" CommandParameter="True" Foreground="White" Background="#20FFFFFF" BorderThickness="0" 
                            FontSize="{DynamicResource FontSize_14}" Cursor="Hand" Margin="0,0,0,15" Padding="12,10" HorizontalContentAlignment="Left"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="⚙️ Configurações" Foreground="#AAA" Background="Transparent" BorderThickness="0" 
                                FontSize="{DynamicResource FontSize_13}" Cursor="Hand" Margin="0,0,15,0"
                                WindowChrome.IsHitTestVisibleInChrome="True" Click="SettingsButton_Click"/>
                        
                        <Button Content="📈 Insights" Foreground="{DynamicResource PrimaryAccentBrush}" Background="Transparent" BorderThickness="0" 
                                FontSize="{DynamicResource FontSize_13}" Cursor="Hand" 
                                WindowChrome.IsHitTestVisibleInChrome="True" Click="InsightsButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left Splitter -->
        <GridSplitter Grid.Column="1" Width="5" Visibility="{Binding IsLeftSidebarOpen, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" />

        <!-- Center Content -->
        <Grid Grid.Column="2" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- New Header (Tabs & Toggles) -->
                <RowDefinition Height="*"/>    <!-- Daily View or Projects View -->
            </Grid.RowDefinitions>
            
            <!-- Central Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar Toggle -->
                <Button Grid.Column="0" Content="☰ Esquerda" Command="{Binding ToggleLeftSidebarCommand}" 
                        Background="Transparent" BorderThickness="0" Foreground="#AAA" FontSize="{DynamicResource FontSize_12}" Cursor="Hand" ToolTip="Painel Esquerdo" VerticalAlignment="Center" Padding="8"/>

                <!-- Tab Navigation -->
                <Border Grid.Column="1" HorizontalAlignment="Center" Background="#10FFFFFF" CornerRadius="8" Padding="4">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Resources>
                            <Style TargetType="RadioButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}" MinWidth="120">
                                                <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource FontSize_13}" FontWeight="SemiBold"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#30FFFFFF"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter Property="Foreground" Value="#888"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                        <Condition Property="IsChecked" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>
                        <RadioButton Content="Visão Diária" IsChecked="{Binding IsProjectsViewActive, Converter={StaticResource InverseBool}}" Padding="12,8" Cursor="Hand"/>
                        <RadioButton Content="Projetos" IsChecked="{Binding IsProjectsViewActive}" Padding="12,8" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Right Sidebar Toggle & Lightbulb -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,100,0">
                    <Button Content="💡 Ideias" Command="{Binding ToggleQuickIdeasCommand}" 
                            Background="Transparent" BorderThickness="0" Foreground="#FFD700" FontSize="{DynamicResource FontSize_12}" Cursor="Hand" ToolTip="Ideias Rápidas" Margin="0,0,10,0" Padding="8"/>
                    <Button Content="Direita ☰" Command="{Binding ToggleRightSidebarCommand}" 
                            Background="Transparent" BorderThickness="0" Foreground="#AAA" FontSize="{DynamicResource FontSize_12}" Cursor="Hand" ToolTip="Painel Direito" Padding="8"/>
                </StackPanel>
            </Grid>

            <!-- Daily Focus View -->
            <Grid Grid.Row="1" Style="{StaticResource FadeInGridStyle}" Visibility="{Binding IsProjectsViewActive, Converter={StaticResource InverseBoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200" MinHeight="100"/>
                </Grid.RowDefinitions>

            <!-- Focus do Dia -->
            <StackPanel Grid.Row="0" Margin="0,20,0,40">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusModeEnabled}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsTaskDetailMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="Foco do Dia" FontSize="{DynamicResource FontSize_14}" Foreground="#888888" TextTrimming="CharacterEllipsis" Margin="0,0,0,5"/>
                <TextBox x:Name="FocusTextBox" FontSize="{DynamicResource FontSize_24}" FontWeight="SemiBold" Foreground="White" Background="Transparent" BorderThickness="0" 
                         Text="{Binding DailyFocus, UpdateSourceTrigger=PropertyChanged}" Opacity="0.8" />
                <Rectangle Height="1" Fill="#30FFFFFF" Margin="0,5,0,0" />
            </StackPanel>

            <!-- Task Manager -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusModeEnabled}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsTaskDetailMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#1E1E1E" BorderBrush="#30FFFFFF" BorderThickness="1,1,0,1" CornerRadius="4,0,0,4">
                        <Grid>
                            <ToggleButton x:Name="TagMenuButton" IsChecked="{Binding IsTagMenuOpen, Mode=TwoWay}"
                                          Command="{Binding OpenTagMenuCommand}"
                                          Background="Transparent" BorderThickness="0" Foreground="White"
                                          Width="140" Padding="8,8" FontSize="{DynamicResource FontSize_13}" VerticalAlignment="Center" Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" CornerRadius="4,0,0,4">
                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid>
                                    <TextBlock Text="Tag +" FontWeight="SemiBold" Foreground="#888" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTagItem.Name}" Value="Sem Tag">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedTagItem}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTagItem.Name}" Value="Sem Tag">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedTagItem}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Ellipse Width="10" Height="10" Fill="{Binding SelectedTagItem.ColorHex}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedTagItem.Name}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                                    </StackPanel>
                                </Grid>
                            </ToggleButton>

                            <!-- Popup for Menu -->
                            <Popup IsOpen="{Binding IsTagMenuOpen}" PlacementTarget="{Binding ElementName=TagMenuButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" VerticalOffset="4">
                                <Border Background="#2B2B2B" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="8" Padding="10" Width="220" Margin="0,0,10,10">
                                    <!-- Drop Shadow -->
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.5" Direction="270" ShadowDepth="4"/>
                                    </Border.Effect>
                                    
                                    <Grid>
                                        <!-- TAG LIST -->
                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditingTag}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            
                                            <TextBlock Text="Selecione uma Tag" Foreground="#AAA" FontSize="{DynamicResource FontSize_11}" Margin="0,0,0,10" FontWeight="SemiBold"/>
                                            
                                            <ItemsControl ItemsSource="{Binding AvailableTags}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!-- Item container doing selection and hover styling -->
                                                        <Grid Background="Transparent" Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <!-- Select tag button -->
                                                            <Button Command="{Binding DataContext.SelectTagCommand, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                                    CommandParameter="{Binding}"
                                                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,6"
                                                                    HorizontalContentAlignment="Left">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                            <ContentPresenter/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="#1AFFFFFF"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="10" Height="10" Fill="{Binding ColorHex}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                    <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center" FontSize="{DynamicResource FontSize_12}"/>
                                                                </StackPanel>
                                                            </Button>
                                                            
                                                            <!-- Edit Tag -->
                                                            <Button Grid.Column="1" Content="✏️" FontSize="{DynamicResource FontSize_10}" Background="Transparent" BorderThickness="0" Foreground="#AAA" Cursor="Hand" Margin="0,0,4,0" Padding="4"
                                                                    Command="{Binding DataContext.StartEditTagCommand, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Name}" Value="Sem Tag">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                            
                                                            <!-- Delete Tag -->
                                                            <Button Grid.Column="2" Content="✖" FontSize="{DynamicResource FontSize_10}" Background="Transparent" BorderThickness="0" Foreground="#FF3B30" Cursor="Hand" Padding="4"
                                                                    Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Name}" Value="Sem Tag">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            
                                            <Rectangle Height="1" Fill="#20FFFFFF" Margin="0,10,0,5"/>
                                            <Button Content="+ Criar Nova Tag" Command="{Binding StartCreateTagCommand}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryAccentBrush}" Cursor="Hand" FontWeight="SemiBold" Padding="4"/>
                                        </StackPanel>
                                        
                                        <!-- EDIT/CREATE TAG PANEL -->
                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditingTag}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            
                                            <TextBlock Text="Editar Tag" Foreground="#AAA" FontSize="{DynamicResource FontSize_11}" Margin="0,0,0,10" FontWeight="SemiBold"/>
                                            
                                            <TextBox Text="{Binding EditingTag.Name, UpdateSourceTrigger=PropertyChanged}" Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" Foreground="White" Padding="6" Margin="0,0,0,10">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                            
                                            <TextBlock Text="Cores" Foreground="#AAA" FontSize="{DynamicResource FontSize_10}" Margin="0,0,0,5"/>
                                            <ItemsControl ItemsSource="{Binding ColorPalette}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="6" Rows="2"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!-- Command to set color -->
                                                        <Button Background="{Binding}" Width="20" Height="20" Margin="3" BorderThickness="0" Cursor="Hand"
                                                                Command="{Binding DataContext.SetEditingColorCommand, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="#80FFFFFF">
                                                                        <!-- Minimal selection style logic can go here -->
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,10" HorizontalAlignment="Center">
                                                <Ellipse Width="16" Height="16" Fill="{Binding EditingTag.ColorHex}" Margin="0,0,8,0"/>
                                                <!-- We can just display string for manual color input -->
                                                <TextBox Text="{Binding EditingTag.ColorHex, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="{DynamicResource FontSize_12}" Width="65" TextAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <Grid Margin="0,5,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Cancel & Save -->
                                                <Button Content="Cancelar" Command="{Binding CancelEditTagCommand}" Background="#20FFFFFF" BorderThickness="0" Foreground="White" Padding="0,6" Cursor="Hand">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                                <Button Grid.Column="2" Content="Salvar" Command="{Binding SaveTagCommand}" Background="{DynamicResource PrimaryAccentBrush}" BorderThickness="0" Foreground="White" Padding="0,6" Cursor="Hand" FontWeight="SemiBold">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>

                    <TextBox Grid.Column="1" Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}" 
                             Foreground="White" Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="0,1,1,1" 
                             Padding="10,8" FontSize="{DynamicResource FontSize_14}" VerticalAlignment="Stretch">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="0,4,4,0"/>
                            </Style>
                        </TextBox.Resources>
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AddTaskCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    
                    <Button Grid.Column="2" Command="{Binding AddTaskCommand}" Content="+" 
                            Foreground="White" Background="{DynamicResource PrimaryAccentBrush}" BorderThickness="0" 
                            Width="36" FontSize="{DynamicResource FontSize_20}" FontWeight="Bold" Margin="10,0,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="{DynamicResource GlobalCornerRadius}"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Tasks}" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tasks.Count}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <TextBlock Text="Organize seu dia. Adicione uma tarefa acima! 🚀" 
                                                               Foreground="#60FFFFFF" FontSize="{DynamicResource FontSize_13}" FontStyle="Italic" 
                                                               HorizontalAlignment="Center" Margin="0,30,0,0"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#10FFFFFF" CornerRadius="6" Margin="0,0,0,8" Padding="10" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick" 
                                                      Command="{Binding DataContext.NavigateToTaskDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                     Background="Transparent" BorderThickness="0" Foreground="White" FontSize="{DynamicResource FontSize_14}" VerticalAlignment="Center"
                                                     Style="{DynamicResource StrikethroughStyle}"/>
                                            
                                            <!-- Tag Label -->
                                            <Border Grid.Column="2" CornerRadius="4" Padding="6,2" Margin="10,0,10,0" VerticalAlignment="Center" Cursor="Hand">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftDoubleClick" 
                                                                  Command="{Binding DataContext.EditSpecificTagCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Background" Value="{Binding TagColor}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Tag}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                    <TextBlock Text="{Binding Tag}" FontSize="{DynamicResource FontSize_10}" Foreground="White" FontWeight="SemiBold"/>
                                                </Border>

                                                <Button Grid.Column="3" Content="➜" 
                                                        Command="{Binding DataContext.NavigateToTaskDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Entrar na tarefa"
                                                        Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                                                        FontSize="{DynamicResource FontSize_14}"/>

                                                <Button Grid.Column="4" Content="✖" 
                                                        Command="{Binding DataContext.RemoveTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}"
                                                        Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                            </Grid>
                                            <!-- Task Description -->
                                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="Transparent" BorderThickness="0" Foreground="#999" FontSize="{DynamicResource FontSize_11}" FontStyle="Italic"
                                                     Margin="28,2,0,0" TextWrapping="Wrap"
                                                     local:PlaceholderHelper.Placeholder="Adicionar descrição..."/>
                                            
                                            <!-- Progress bar visual -->
                                            <Grid Margin="28,6,0,2" Height="4">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CompletionPercent}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Border Background="#20FFFFFF" CornerRadius="2"/>
                                                <Border Background="{DynamicResource PrimaryAccentBrush}" CornerRadius="2" HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                                            <Binding Path="CompletionPercent"/>
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>

                                            <!-- Sub-tasks list -->
                                            <ItemsControl ItemsSource="{Binding NoteBlocks}" Margin="20,6,0,0">
                                                <ItemsControl.Resources>
                                                    <DataTemplate DataType="{x:Type models:TextBlockItem}">
                                                        <Grid Height="0" Visibility="Collapsed"/>
                                                    </DataTemplate>
                                                    <DataTemplate DataType="{x:Type models:TaskItem}">
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                                     Background="Transparent" BorderThickness="0" Foreground="#CCC" FontSize="{DynamicResource FontSize_12}" VerticalAlignment="Center"
                                                                     Style="{DynamicResource StrikethroughStyle}"/>
                                                            <Button Grid.Column="2" Content="✖" FontSize="{DynamicResource FontSize_8}" Padding="1" MinWidth="14" MinHeight="14"
                                                                    Command="{Binding DataContext.RemoveSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}" Foreground="#666" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.Resources>
                                            </ItemsControl>

                                            <!-- Add sub-task button -->
                                            <Button Content="+ Sub-tarefa" HorizontalAlignment="Left" Margin="20,4,0,0" Padding="0" FontSize="{DynamicResource FontSize_11}"
                                                    Command="{Binding DataContext.AddSubTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                        </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Center Vertical Splitter -->
            <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" Cursor="SizeNS" Margin="0,10,0,10">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusModeEnabled}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsTaskDetailMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- Scratchpad -->
            <Border Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="15" Margin="0,0,0,0"
                    BorderBrush="#20FFFFFF" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Grid.Row" Value="3" />
                        <Setter Property="Grid.RowSpan" Value="1" />
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusModeEnabled}" Value="True">
                                <Setter Property="Grid.Row" Value="0" />
                                <Setter Property="Grid.RowSpan" Value="4" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsTaskDetailMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Scratchpad" Foreground="#888" FontSize="{DynamicResource FontSize_12}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ToggleFocusModeCommand}" 
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Content" Value="🔍 Modo Foco"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFocusModeEnabled}" Value="True">
                                            <Setter Property="Content" Value="? Sair do Foco"/>
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <localControls:NotepadEditor Grid.Row="1" Margin="0,15,0,0" 
                                                 Text="{Binding ScratchpadText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Border>

            <!-- Task Detail Mode -->
            <Grid Grid.Row="0" Grid.RowSpan="4">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTaskDetailMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Margin="0,20,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="? Voltar" Command="{Binding CloseTaskDetailCommand}" 
                            Background="#1AFFFFFF" BorderThickness="0" Foreground="#AAA" Cursor="Hand" FontSize="{DynamicResource FontSize_12}" FontWeight="SemiBold" Padding="8,4" Margin="0,0,15,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedTaskForDetails.Title}" FontSize="{DynamicResource FontSize_24}" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </Grid>

                <!-- Notepad Area -->
                <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="20" BorderBrush="#20FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header & Add buttons -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Anotações e Detalhes" Foreground="#888" FontSize="{DynamicResource FontSize_12}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Unified Editor Space -->
                        <localControls:NotepadEditor Grid.Row="1" Margin="0,5,0,0"
                                                     Text="{Binding SelectedTaskForDetails.NotesMarkdown, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>
            </Grid>
            </Grid>

            <!-- Projects Kanban View -->
            <Grid Grid.Row="1" Style="{StaticResource FadeInGridStyle}" Visibility="{Binding IsProjectsViewActive, Converter={StaticResource BoolToVis}}">
                
                <!-- Main Kanban Board Layer -->
                <Grid Visibility="{Binding IsProjectDetailMode, Converter={StaticResource InverseBoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                <!-- Inbox Column -->
                <Border Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="12" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="📥 Caixa de Entrada" Foreground="White" FontSize="{DynamicResource FontSize_16}" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Basic Add Button at Top -->
                                <Button Content="+ Nova Ideia" Command="{Binding AddProjectIdeaCommand}" CommandParameter="Inbox" Background="#10FFFFFF" Foreground="White" BorderThickness="0" HorizontalAlignment="Stretch" Cursor="Hand" Margin="0,0,0,15" Padding="10,8">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                                <ItemsControl ItemsSource="{Binding ProjectInbox}" ItemTemplate="{StaticResource KanbanCardTemplate}" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True">
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Analyzing Column -->
                <Border Grid.Column="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="12" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="🔍 Analisando" Foreground="White" FontSize="{DynamicResource FontSize_16}" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Button Content="+ Nova Ideia" Command="{Binding AddProjectIdeaCommand}" CommandParameter="Analyzing" Background="#10FFFFFF" Foreground="White" BorderThickness="0" HorizontalAlignment="Stretch" Cursor="Hand" Margin="0,0,0,15" Padding="10,8">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                                <ItemsControl ItemsSource="{Binding ProjectAnalyzing}" ItemTemplate="{StaticResource KanbanCardTemplate}" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True">
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Someday Column -->
                <Border Grid.Column="4" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="12" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="☁️ Talvez um Dia" Foreground="White" FontSize="{DynamicResource FontSize_16}" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Button Content="+ Nova Ideia" Command="{Binding AddProjectIdeaCommand}" CommandParameter="Someday" Background="#10FFFFFF" Foreground="White" BorderThickness="0" HorizontalAlignment="Stretch" Cursor="Hand" Margin="0,0,0,15" Padding="10,8">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                                <ItemsControl ItemsSource="{Binding ProjectSomeday}" ItemTemplate="{StaticResource KanbanCardTemplate}" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True">
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
                </Grid>

                <!-- Project Idea Detail Mode Layer -->
                <Grid Margin="20,0,20,20" Visibility="{Binding IsProjectDetailMode, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="? Voltar" Command="{Binding CloseProjectIdeaDetailCommand}" 
                                Background="#1AFFFFFF" BorderThickness="0" Foreground="#AAA" Cursor="Hand" FontSize="{DynamicResource FontSize_12}" FontWeight="SemiBold" Padding="8,4" Margin="0,0,15,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <TextBox Grid.Column="1" Text="{Binding SelectedProjectIdeaForDetails.Title, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="{DynamicResource FontSize_24}" FontWeight="Bold" Foreground="White" 
                                 Background="Transparent" BorderThickness="0" VerticalAlignment="Center" 
                                 TextWrapping="Wrap"/>
                    </Grid>

                    <!-- Notepad Area -->
                    <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="20" BorderBrush="#20FFFFFF" BorderThickness="1">
                        <localControls:NotepadEditor Text="{Binding SelectedProjectIdeaForDetails.NotesMarkdown, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                </Grid>

            </Grid>
        <!-- End Center Content -->
        </Grid>

        <!-- Right Splitter -->
        <GridSplitter Grid.Column="3" Width="5" Visibility="{Binding IsRightSidebarOpen, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" />

        <!-- Right Panel (Goals/Heatmap/Orb) -->
        <Border Grid.Column="4" MinWidth="300" Style="{StaticResource FadeInGridStyle}" Visibility="{Binding IsRightSidebarOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="#20FFFFFF" BorderThickness="1,0,0,0" Padding="20">
            <Grid>
                <!-- Original Goals & Stats View -->
                <Grid Visibility="{Binding IsQuickIdeasActive, Converter={StaticResource InverseBoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <ToggleButton Grid.Row="0" IsChecked="{Binding IsWeeklyGoalsExpanded, FallbackValue=True}" Command="{Binding ToggleWeeklyGoalsCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,10,0,15" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Grid Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Metas Semanais" FontSize="{DynamicResource FontSize_18}" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Grid.Column="1" Text="▼" Foreground="#AAA" VerticalAlignment="Center" x:Name="chevron" FontSize="10"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter TargetName="chevron" Property="Text" Value="▶"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="chevron" Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    
                    <!-- Scrollable goals area -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" Visibility="{Binding IsWeeklyGoalsExpanded, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding WeeklyGoals}" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WeeklyGoals.Count}" Value="0">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <TextBlock Text="Nenhuma meta semanal definida. 🎯" 
                                                                   Foreground="#60FFFFFF" FontSize="{DynamicResource FontSize_12}" FontStyle="Italic" 
                                                                   HorizontalAlignment="Center" Margin="0,20,0,20"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#10FFFFFF" CornerRadius="8" Margin="0,0,0,10" Padding="10">
                                        <StackPanel>
                                            <!-- Goal header: checkbox + title + remove -->
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <CheckBox IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Margin="0,4,8,0"/>
                                                
                                                <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                         Background="Transparent" BorderThickness="0" Foreground="White" FontSize="{DynamicResource FontSize_13}" FontWeight="SemiBold" VerticalAlignment="Top"
                                                         TextWrapping="Wrap" Style="{DynamicResource StrikethroughStyle}" Margin="0,2,8,2"/>
                                                
                                                <Button Grid.Column="2" Content="✖" FontSize="{DynamicResource FontSize_10}" Padding="2" MinWidth="18" MinHeight="18"
                                                        Command="{Binding DataContext.RemoveGoalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}" Foreground="#666" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>

                                                <!-- Action row -->
                                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,4">
                                                    <Border CornerRadius="4" Padding="4,1" Margin="0,0,8,0" VerticalAlignment="Center" Cursor="Hand" Background="{Binding TagColor}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Tag}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftDoubleClick" 
                                                                          Command="{Binding DataContext.EditSpecificTagCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <TextBlock Text="{Binding Tag}" FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                                                    </Border>

                                                    <ToggleButton x:Name="LinkMenuBtnW" Content="? Hoje" FontSize="{DynamicResource FontSize_10}" Padding="6,2" Margin="0,0,8,0"
                                                                  Foreground="#888" Background="#15FFFFFF" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                                        <ToggleButton.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="4"/>
                                                            </Style>
                                                        </ToggleButton.Resources>
                                                    </ToggleButton>
                                                    <Popup IsOpen="{Binding IsChecked, ElementName=LinkMenuBtnW}" PlacementTarget="{Binding ElementName=LinkMenuBtnW}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" VerticalOffset="2">
                                                        <Border Background="#2B2B2B" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="4" Padding="2">
                                                            <StackPanel>
                                                                <Button Content="Enviar para Hoje (Manter Vínculo)" Command="{Binding DataContext.LinkGoalToTodayCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                <Button Content="Enviar para Hoje (Apenas Cópia)" Command="{Binding DataContext.CopyGoalToTodayCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                <Button Content="Enviar para Mensal (Manter Vínculo)" Command="{Binding DataContext.LinkGoalToMonthlyCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                <Button Content="Enviar para Mensal (Apenas Cópia)" Command="{Binding DataContext.CopyGoalToMonthlyCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Popup>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Description for weekly goal -->
                                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="Transparent" BorderThickness="0" Foreground="#AAA" FontSize="{DynamicResource FontSize_11}" FontStyle="Italic"
                                                     Margin="24,2,0,0" TextWrapping="Wrap"
                                                     local:PlaceholderHelper.Placeholder="Adicionar descrição..."/>

                                            <!-- Deadline -->
                                            <StackPanel Orientation="Horizontal" Margin="24,4,0,0">
                                                <TextBlock Text="Prazo:" Foreground="#888" FontSize="{DynamicResource FontSize_10}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <ToggleButton x:Name="DeadlineBtnW" Foreground="#FFF" Background="#20FFFFFF" BorderThickness="0" Cursor="Hand" Padding="6,2" VerticalAlignment="Center">
                                                    <ToggleButton.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </ToggleButton.Resources>
                                                    <TextBlock Text="{Binding Deadline, StringFormat='{}{0:dd/MM/yyyy}', TargetNullValue='Selecionar data'}" FontSize="{DynamicResource FontSize_10}"/>
                                                </ToggleButton>
                                                <Popup IsOpen="{Binding IsChecked, ElementName=DeadlineBtnW}" StaysOpen="False" PlacementTarget="{Binding ElementName=DeadlineBtnW}" Placement="Bottom" AllowsTransparency="True" VerticalOffset="2">
                                                    <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="8" Padding="10">
                                                        <local:CustomCalendar SelectedDate="{Binding Deadline, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Border>
                                                </Popup>
                                                <Button Content="✖" Foreground="#A44" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" Padding="2" FontSize="{DynamicResource FontSize_8}"
                                                        Click="ClearDeadline_Click" Tag="{Binding}" VerticalAlignment="Center" ToolTip="Remover Prazo">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Deadline}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>

                                            <!-- Completion Slider -->
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Minimum="0" Maximum="100" 
                                                        Value="{Binding CompletionPercent, UpdateSourceTrigger=PropertyChanged}" 
                                                        VerticalAlignment="Center" Margin="0,0,8,0"
                                                        Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                                <TextBlock Grid.Column="1" Foreground="#AAA" FontSize="{DynamicResource FontSize_11}" VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <Binding Path="CompletionPercent" StringFormat="{}{0}%"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Grid>
                                            
                                            <!-- Progress bar visual -->
                                            <Grid Margin="0,4,0,2" Height="4">
                                                <Border Background="#20FFFFFF" CornerRadius="2"/>
                                                <Border Background="{DynamicResource PrimaryAccentBrush}" CornerRadius="2" HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                                            <Binding Path="CompletionPercent"/>
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>

                                            <!-- Sub-tasks list -->
                                            <ItemsControl ItemsSource="{Binding NoteBlocks}" Margin="20,6,0,0">
                                                <ItemsControl.Resources>
                                                    <DataTemplate DataType="{x:Type models:TextBlockItem}">
                                                        <Grid Height="0" Visibility="Collapsed"/>
                                                    </DataTemplate>
                                                    <DataTemplate DataType="{x:Type models:TaskItem}">
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Margin="0,2,6,0"/>
                                                            <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                                     Background="Transparent" BorderThickness="0" Foreground="#CCC" FontSize="{DynamicResource FontSize_12}" VerticalAlignment="Top"
                                                                     TextWrapping="Wrap" Style="{DynamicResource StrikethroughStyle}"/>
                                                            <ToggleButton x:Name="LinkMenuBtnWSub" Grid.Column="2" Content="➡" FontSize="{DynamicResource FontSize_8}" Padding="3,1" Margin="0,0,6,0"
                                                                          Foreground="#AAA" Background="#20FFFFFF" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                                                <ToggleButton.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="4"/>
                                                                    </Style>
                                                                </ToggleButton.Resources>
                                                            </ToggleButton>
                                                            <Popup IsOpen="{Binding IsChecked, ElementName=LinkMenuBtnWSub}" PlacementTarget="{Binding ElementName=LinkMenuBtnWSub}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" VerticalOffset="2">
                                                                <Border Background="#2B2B2B" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="4" Padding="2">
                                                                    <StackPanel>
                                                                        <Button Content="Enviar para Hoje (Manter Vínculo)" Command="{Binding DataContext.LinkGoalToTodayCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                        <Button Content="Enviar para Hoje (Apenas Cópia)" Command="{Binding DataContext.CopyGoalToTodayCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                        <Button Content="Enviar para Mensal (Manter Vínculo)" Command="{Binding DataContext.LinkGoalToMonthlyCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                        <Button Content="Enviar para Mensal (Apenas Cópia)" Command="{Binding DataContext.CopyGoalToMonthlyCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,4" HorizontalContentAlignment="Left" FontSize="{DynamicResource FontSize_11}"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Popup>
                                                            <Button Grid.Column="3" Content="✖" FontSize="{DynamicResource FontSize_8}" Padding="1" MinWidth="14" MinHeight="14"
                                                                    Command="{Binding DataContext.RemoveSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}" Foreground="#666" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.Resources>
                                            </ItemsControl>

                                            <!-- Add sub-task button -->
                                            <Button Content="+ Sub-tarefa" HorizontalAlignment="Left" Margin="20,4,0,0" Padding="0" FontSize="{DynamicResource FontSize_11}"
                                                    Command="{Binding DataContext.AddSubTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add new goal input -->
                        <TextBox Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#40FFFFFF" Foreground="#AAA"
                                 Margin="0,5,0,0" Text="{Binding NewGoalTitle, UpdateSourceTrigger=PropertyChanged}" Padding="0,5">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddGoalCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Content="+ Adicionar Meta" Command="{Binding AddGoalCommand}" HorizontalAlignment="Left" Background="Transparent" Foreground="{DynamicResource PrimaryAccentBrush}" BorderThickness="0" Cursor="Hand" Margin="0,5,0,0"/>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Contribution Heatmap -->
                <Border Grid.Row="2" Background="#08FFFFFF" CornerRadius="12" Padding="15" Margin="0,5,0,15">
                    <StackPanel>
                        <TextBlock Text="Contribuições" FontSize="{DynamicResource FontSize_12}" Foreground="#888" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                        <localControls:HeatmapControl 
                            ContributionData="{Binding ContributionHistory}" 
                            CellSize="10" CellSpacing="3"
                            HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                
                <!-- Liquid Progress Orb Replacement -->
                <Grid Grid.Row="3" Height="140" Margin="0,5,0,0">
                    <localControls:CircularProgressBar 
                        Value="{Binding ProgressPercentage}" 
                        StrokeThickness="8" 
                        Width="110" Height="110" 
                        ProgressBrush="{DynamicResource PrimaryAccentBrush}"
                        TrackBrush="#15FFFFFF"/>
                    
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ProgressPercentage, StringFormat=\{0:0\}%}" Foreground="White" FontSize="{DynamicResource FontSize_24}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Concluído" Foreground="#666" FontSize="{DynamicResource FontSize_9}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                </Grid>

                <!-- Quick Ideas View -->
                <Grid Visibility="{Binding IsQuickIdeasActive, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="💡 Ideias Rápidas" FontSize="{DynamicResource FontSize_18}" FontWeight="SemiBold" Foreground="#FFD700" Margin="0,10,0,15" />
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Button Content="+ Ideia na Caixa de Entrada" Command="{Binding AddProjectIdeaCommand}" CommandParameter="Inbox" Background="#10FFFFFF" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,15" Padding="10,8">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <TextBlock Text="Caixa de Entrada" FontSize="{DynamicResource FontSize_13}" FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding ProjectInbox}" ItemTemplate="{StaticResource KanbanCardTemplate}" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True" dd:DragDrop.DropHandler="{Binding}" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="Analisando" FontSize="{DynamicResource FontSize_13}" FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding ProjectAnalyzing}" ItemTemplate="{StaticResource KanbanCardTemplate}" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True" dd:DragDrop.DropHandler="{Binding}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
        </Grid> <!-- End Main Layout -->

        <!-- Window Controls -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,25,0" WindowChrome.IsHitTestVisibleInChrome="True" Panel.ZIndex="100">
            <Button Content="—" Width="45" Height="32" Margin="0,0,12,0" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="{DynamicResource FontSize_18}" Cursor="Hand" Click="MinimizeButton_Click"/>
            <Button Content="🗖" Width="45" Height="32" Margin="0,0,12,0" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="{DynamicResource FontSize_18}" Cursor="Hand" Click="MaximizeButton_Click"/>
            <Button x:Name="CloseButton" Content="✖" Width="45" Height="32" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="{DynamicResource FontSize_18}" Cursor="Hand" Click="CloseButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

    </Grid>
</Window>


