<UserControl x:Class="DailyDash.Controls.NotepadEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DailyDash.Controls">
    <Grid>
        <RichTextBox x:Name="EditorBox" Background="Transparent" Foreground="White" BorderThickness="0"
                     AcceptsReturn="True" SpellCheck.IsEnabled="False"
                     PreviewDragOver="EditorBox_PreviewDragOver" Drop="EditorBox_Drop"
                     LostFocus="EditorBox_LostFocus"
                     Padding="0,5,0,5"
                     CaretBrush="White">
            <RichTextBox.Resources>
                <Style TargetType="{x:Type Paragraph}">
                    <Setter Property="Margin" Value="0,2,0,2"/>
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>
    </Grid>
</UserControl>
