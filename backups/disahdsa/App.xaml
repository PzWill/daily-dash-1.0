<Application x:Class="DailyDash.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DailyDash"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <!-- Application global resources, generic styles, colors -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Default Values (Will be overridden by SettingsManager on startup) -->
            <Color x:Key="AppBackgroundColor">#1E1E1E</Color>
            <Color x:Key="PanelBackgroundColor">#99000000</Color> 
            <Color x:Key="PrimaryAccentColor">#0078D7</Color>
            
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{DynamicResource AppBackgroundColor}"/>
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{DynamicResource PanelBackgroundColor}"/>
            <SolidColorBrush x:Key="PrimaryAccentBrush" Color="{DynamicResource PrimaryAccentColor}"/>
            
            <CornerRadius x:Key="GlobalCornerRadius">12</CornerRadius>
            
            <!-- Global Text Colors to override Default WPF Control Colors (like Calendar Headers) -->
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
            <Color x:Key="{x:Static SystemColors.WindowTextColorKey}">White</Color>
            
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
            <Color x:Key="{x:Static SystemColors.ControlTextColorKey}">White</Color>
            
            <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#99FFFFFF"/>
            <Color x:Key="{x:Static SystemColors.GrayTextColorKey}">#99FFFFFF</Color>
            
            <!-- Calendar Dark Mode Styles -->
            <Style TargetType="Calendar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>
            <Style TargetType="CalendarDayButton">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style TargetType="CalendarButton">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

