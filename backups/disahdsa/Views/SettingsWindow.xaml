<Window x:Class="DailyDash.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConfiguraÃ§Ãµes" Height="500" Width="400"
        Background="{DynamicResource AppBackgroundBrush}" Foreground="White" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{DynamicResource PanelBackgroundBrush}" Padding="20,15" BorderBrush="#20FFFFFF" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="âš™ï¸ ConfiguraÃ§Ãµes" Foreground="White" FontSize="{DynamicResource FontSize_20}" FontWeight="SemiBold" VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="âœ–" Width="30" Height="30" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="{DynamicResource FontSize_16}" Cursor="Hand" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" Margin="20" CornerRadius="8" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    
                    <TextBlock Text="AparÃªncia Global" FontSize="{DynamicResource FontSize_16}" FontWeight="SemiBold" Foreground="#FFD700" Margin="0,0,0,15"/>
                    <Border Background="#10FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Opacidade dos PainÃ©is Glass" Margin="0,0,0,10" Foreground="#AAA"/>
                            <Slider Minimum="0.1" Maximum="1.0" Value="0.6" x:Name="OpacitySlider" Margin="0,0,0,15" TickFrequency="0.1" IsSnapToTickEnabled="True"/>

                            <TextBlock Text="Arredondamento das Bordas (Radius)" Margin="0,0,0,10" Foreground="#AAA"/>
                            <Slider Minimum="0" Maximum="30" Value="12" x:Name="RadiusSlider" Margin="0,0,0,15" TickFrequency="1" IsSnapToTickEnabled="True"/>

                            <TextBlock Text="Cor de Destaque (Hexadecimal)" Margin="0,0,0,10" Foreground="#AAA"/>
                            <TextBox x:Name="ColorTextBox" Text="#0078D7" Width="120" HorizontalAlignment="Left" Padding="8" Margin="0,0,0,5" Background="#303030" Foreground="White" BorderThickness="1" BorderBrush="#555"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Acessibilidade e Texto" FontSize="{DynamicResource FontSize_16}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryAccentBrush}" Margin="0,0,0,15"/>
                    <Border Background="#10FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Tamanho da Fonte Principal" Margin="0,0,0,10" Foreground="#AAA"/>
                            <Slider Minimum="10" Maximum="24" Value="14" x:Name="FontSizeSlider" Margin="0,0,0,5" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,10,0,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="Salvar e Aplicar" Height="40" Click="SaveButton_Click" Background="{DynamicResource PrimaryAccentBrush}" Foreground="White" BorderThickness="0" FontWeight="SemiBold" FontSize="{DynamicResource FontSize_14}" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="{DynamicResource GlobalCornerRadius}"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>

