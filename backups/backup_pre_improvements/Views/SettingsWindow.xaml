<Window x:Class="DailyDash.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurações" Height="420" Width="350"
        WindowStyle="ToolWindow" Background="#202020" Foreground="White" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="25">
        <StackPanel>
            <TextBlock Text="Configurações" FontSize="22" FontWeight="Bold" Margin="0,0,0,25" Foreground="White"/>
            
            <TextBlock Text="Opacidade dos Painéis Glass" Margin="0,0,0,10" Foreground="#AAA"/>
            <Slider Minimum="0.1" Maximum="1.0" Value="0.6" x:Name="OpacitySlider" Margin="0,0,0,20" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
            
            <TextBlock Text="Arredondamento das Bordas (Radius)" Margin="0,0,0,10" Foreground="#AAA"/>
            <Slider Minimum="0" Maximum="30" Value="12" x:Name="RadiusSlider" Margin="0,0,0,20" TickFrequency="1" IsSnapToTickEnabled="True"/>
            
            <TextBlock Text="Cor de Destaque (Hexadecimal)" Margin="0,0,0,10" Foreground="#AAA"/>
            <TextBox x:Name="ColorTextBox" Text="#0078D7" Width="120" HorizontalAlignment="Left" Padding="8" Margin="0,0,0,30" Background="#303030" Foreground="White" BorderThickness="1" BorderBrush="#555"/>
            
            <Grid>
                <Button Content="Salvar e Aplicar" Height="35" Click="SaveButton_Click" Background="#0078D7" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
