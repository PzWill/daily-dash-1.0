<Window x:Class="DailyDash.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DailyDash.Views"
        Title="Daily Dash" Height="700" Width="1100"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- No calendar styles needed - using custom calendar control -->
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <!-- GlassFrameThickness=-1 enables the DWM glass effect to cover the entire window -->
        <WindowChrome GlassFrameThickness="-1" CaptionHeight="0" ResizeBorderThickness="8" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <!-- Global Grid Overlay to give a bit of tint over the acrylic blur -->
    <Grid Background="#401A1A1A" x:Name="RootLayout">
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="280" />
            <!-- Main Content -->
            <ColumnDefinition Width="*" />
            <!-- Right Panel (Goals/Heatmap) -->
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar (Left) -->
        <Border Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="#20FFFFFF" BorderThickness="0,0,1,0" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Daily Dash" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,10,0,30" />
                
                <local:CustomCalendar Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,0,0,20"
                                      SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                
                <!-- Monthly Goals Section in Sidebar -->
                <Border Grid.Row="2" Background="#10FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Metas Mensais" FontSize="16" FontWeight="SemiBold" Foreground="#FFD700" Margin="0,0,0,10"/>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding MonthlyGoals}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#10FFFFFF" CornerRadius="6" Margin="0,0,0,8" Padding="8">
                                                <StackPanel>
                                                    <!-- Goal header: checkbox + title + remove -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                                 Background="Transparent" BorderThickness="0" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="2" Content="✕" FontSize="9" Padding="2" MinWidth="16" MinHeight="16"
                                                                Command="{Binding DataContext.RemoveMonthlyGoalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                                CommandParameter="{Binding}" Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"/>
                                                    </Grid>

                                                    <!-- Description -->
                                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                             Background="Transparent" BorderThickness="0" Foreground="#AAA" FontSize="10" FontStyle="Italic"
                                                             Margin="22,2,0,0" TextWrapping="Wrap"
                                                             local:PlaceholderHelper.Placeholder="Adicionar descrição..."/>

                                                    <!-- Completion Slider -->
                                                    <Grid Margin="0,4,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Slider Minimum="0" Maximum="100" 
                                                                Value="{Binding CompletionPercent, UpdateSourceTrigger=PropertyChanged}" 
                                                                VerticalAlignment="Center" Margin="0,0,6,0"
                                                                Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                                        <TextBlock Grid.Column="1" Foreground="#AAA" FontSize="10" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <Binding Path="CompletionPercent" StringFormat="{}{0}%"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </Grid>
                                                    
                                                    <!-- Progress bar visual -->
                                                    <Grid Margin="0,3,0,1" Height="3">
                                                        <Border Background="#20FFFFFF" CornerRadius="2"/>
                                                        <Border Background="#FFD700" CornerRadius="2" HorizontalAlignment="Left">
                                                            <Border.Width>
                                                                <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                                                    <Binding Path="CompletionPercent"/>
                                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Sub-tasks list -->
                                                    <ItemsControl ItemsSource="{Binding SubTasks}" Margin="18,4,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <CheckBox IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                    <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                                             Background="Transparent" BorderThickness="0" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                                                                    <Button Grid.Column="2" Content="✕" FontSize="7" Padding="1" MinWidth="12" MinHeight="12"
                                                                            Command="{Binding DataContext.RemoveSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding}" Foreground="#666" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- Add sub-task button -->
                                                    <Button Content="+ Sub-tarefa" HorizontalAlignment="Left" Margin="18,2,0,0" Padding="0" FontSize="10"
                                                            Command="{Binding DataContext.AddMonthlySubTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Add new monthly goal input -->
                                <TextBox Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#40FFFFFF" Foreground="#AAA"
                                         Margin="0,3,0,0" Text="{Binding NewMonthlyGoalTitle, UpdateSourceTrigger=PropertyChanged}" Padding="0,4" FontSize="11"/>
                                <Button Content="+ Adicionar Meta" Command="{Binding AddMonthlyGoalCommand}" HorizontalAlignment="Left" Background="Transparent" Foreground="#FFD700" BorderThickness="0" Cursor="Hand" Margin="0,3,0,0" FontSize="11"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Button Grid.Row="3" Content="⚙️ Configurações" Foreground="#AAA" Background="Transparent" BorderThickness="0" 
                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,20" FontSize="16" Cursor="Hand" 
                        WindowChrome.IsHitTestVisibleInChrome="True" Click="SettingsButton_Click"/>
            </Grid>
        </Border>

        <!-- Window Controls -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,15,0" WindowChrome.IsHitTestVisibleInChrome="True" Panel.ZIndex="100">
            <Button Content="—" Width="30" Height="30" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Cursor="Hand" Click="MinimizeButton_Click"/>
            <Button Content="X" Width="30" Height="30" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Cursor="Hand" Click="CloseButton_Click"/>
        </StackPanel>

        <!-- Center Content -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- Focus do Dia -->
            <StackPanel Grid.Row="0" Margin="0,20,0,40">
                <TextBlock Text="Foco do Dia" FontSize="14" Foreground="#888888" TextTrimming="CharacterEllipsis" Margin="0,0,0,5"/>
                <TextBox x:Name="FocusTextBox" FontSize="24" FontWeight="SemiBold" Foreground="White" Background="Transparent" BorderThickness="0" 
                         Text="{Binding DailyFocus, UpdateSourceTrigger=PropertyChanged}" Opacity="0.8" />
                <Rectangle Height="1" Fill="#30FFFFFF" Margin="0,5,0,0" />
            </StackPanel>

            <!-- Task Manager -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}" 
                             Foreground="White" Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" 
                             Padding="10,8" FontSize="14"/>
                    <Button Grid.Column="1" Command="{Binding AddTaskCommand}" Content="+" 
                            Foreground="White" Background="{DynamicResource PrimaryAccentBrush}" BorderThickness="0" 
                            Width="36" FontSize="20" FontWeight="Bold" Margin="10,0,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="{DynamicResource GlobalCornerRadius}"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Tasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#10FFFFFF" CornerRadius="6" Margin="0,0,0,8" Padding="10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                     Background="Transparent" BorderThickness="0" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Content="X" 
                                                    Command="{Binding DataContext.RemoveTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                    CommandParameter="{Binding}"
                                                    Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                        </Grid>
                                        <!-- Task Description -->
                                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0" Foreground="#999" FontSize="11" FontStyle="Italic"
                                                 Margin="28,2,0,0" TextWrapping="Wrap"
                                                 local:PlaceholderHelper.Placeholder="Adicionar descrição..."/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Scratchpad -->
            <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="15" Margin="0,20,0,0"
                    BorderBrush="#20FFFFFF" BorderThickness="1">
                <Grid>
                    <TextBlock Text="Scratchpad" Foreground="#888" FontSize="12" VerticalAlignment="Top" />
                    <TextBox Background="Transparent" BorderThickness="0" Foreground="White" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,20,0,0" 
                             Text="{Binding ScratchpadText, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Right Panel (Goals/Heatmap/Orb) -->
        <Border Grid.Column="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="#20FFFFFF" BorderThickness="1,0,0,0" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Metas Semanais" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,10,0,15" />
                
                <!-- Scrollable goals area -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding WeeklyGoals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#10FFFFFF" CornerRadius="8" Margin="0,0,0,10" Padding="10">
                                        <StackPanel>
                                            <!-- Goal header: checkbox + title + remove -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                         Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <Button Grid.Column="2" Content="✕" FontSize="10" Padding="2" MinWidth="18" MinHeight="18"
                                                        Command="{Binding DataContext.RemoveGoalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}" Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Description for weekly goal -->
                                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="Transparent" BorderThickness="0" Foreground="#AAA" FontSize="11" FontStyle="Italic"
                                                     Margin="24,2,0,0" TextWrapping="Wrap"
                                                     local:PlaceholderHelper.Placeholder="Adicionar descrição..."/>

                                            <!-- Completion Slider -->
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Minimum="0" Maximum="100" 
                                                        Value="{Binding CompletionPercent, UpdateSourceTrigger=PropertyChanged}" 
                                                        VerticalAlignment="Center" Margin="0,0,8,0"
                                                        Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                                <TextBlock Grid.Column="1" Foreground="#AAA" FontSize="11" VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <Binding Path="CompletionPercent" StringFormat="{}{0}%"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Grid>
                                            
                                            <!-- Progress bar visual -->
                                            <Grid Margin="0,4,0,2" Height="4">
                                                <Border Background="#20FFFFFF" CornerRadius="2"/>
                                                <Border Background="{DynamicResource PrimaryAccentBrush}" CornerRadius="2" HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                                            <Binding Path="CompletionPercent"/>
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>

                                            <!-- Sub-tasks list -->
                                            <ItemsControl ItemsSource="{Binding SubTasks}" Margin="20,6,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                                     Background="Transparent" BorderThickness="0" Foreground="#CCC" FontSize="12" VerticalAlignment="Center"/>
                                                            <Button Grid.Column="2" Content="✕" FontSize="8" Padding="1" MinWidth="14" MinHeight="14"
                                                                    Command="{Binding DataContext.RemoveSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}" Foreground="#666" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Add sub-task button -->
                                            <Button Content="+ Sub-tarefa" HorizontalAlignment="Left" Margin="20,4,0,0" Padding="0" FontSize="11"
                                                    Command="{Binding DataContext.AddSubTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add new goal input -->
                        <TextBox Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#40FFFFFF" Foreground="#AAA"
                                 Margin="0,5,0,0" Text="{Binding NewGoalTitle, UpdateSourceTrigger=PropertyChanged}" Padding="0,5"/>
                        <Button Content="+ Adicionar Meta" Command="{Binding AddGoalCommand}" HorizontalAlignment="Left" Background="Transparent" Foreground="{DynamicResource PrimaryAccentBrush}" BorderThickness="0" Cursor="Hand" Margin="0,5,0,0"/>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Liquid Progress Orb Placeholder -->
                <Grid Grid.Row="2" Height="160" Margin="0,10,0,0">
                    <Ellipse Stroke="#40FFFFFF" StrokeThickness="4" Width="120" Height="120" />
                    <TextBlock Text="{Binding ProgressPercentage, StringFormat=\{0:0\}%}" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Text="Progresso Diário" Foreground="#888" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0" FontSize="11"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
