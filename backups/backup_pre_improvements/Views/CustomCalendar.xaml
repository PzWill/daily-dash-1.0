<UserControl x:Class="DailyDash.Views.CustomCalendar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <!-- Header: nav arrows + month/year -->
            <RowDefinition Height="Auto"/>
            <!-- Day-of-week labels -->
            <RowDefinition Height="Auto"/>
            <!-- Day grid (6 rows max) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="◀" Click="PrevMonth_Click"
                    Foreground="White" Background="Transparent" BorderThickness="0"
                    FontSize="14" Cursor="Hand" Padding="8,4" VerticalAlignment="Center"/>
            <TextBlock x:Name="MonthYearText" Grid.Column="1" 
                       Foreground="White" FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button Grid.Column="2" Content="▶" Click="NextMonth_Click"
                    Foreground="White" Background="Transparent" BorderThickness="0"
                    FontSize="14" Cursor="Hand" Padding="8,4" VerticalAlignment="Center"/>
        </Grid>

        <!-- Day-of-week headers -->
        <UniformGrid x:Name="DayOfWeekRow" Grid.Row="1" Rows="1" Columns="7" Margin="0,0,0,6"/>

        <!-- Day buttons grid -->
        <UniformGrid x:Name="DaysGrid" Grid.Row="2" Rows="6" Columns="7"/>
    </Grid>
</UserControl>
